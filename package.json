  },
  "keywords": [
    "flowctl",
    "workflow",
    "mcp",
    "cursor",
    "workflow-orchestration",
    "workflow-orchestration-mcp",
    "workflow-orchestration-mcp-server",
    "workflow-orchestration-mcp-server-shell-proxy",
    "workflow-orchestration-mcp-server-workflow-state",
    "shell-proxy",
    "workflow-state"
  ],
  "engines": {
