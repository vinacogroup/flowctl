    }
  },
  "bin": {
    "flowctl": "./bin/flowctl"
  },
  "scripts": {
    "setup-hooks": "node scripts/setup-git-hooks.mjs",
    "flowctl": "flowctl"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
