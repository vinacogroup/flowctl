{
  "name": "@vinacogroup/flowctl",
  "version": "1.0.0",
  "type": "module",
  "description": "Workflow Orchestration for Cursor",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/vinacogroup/flowctl.git"
  },
  "author": "Vinaco Group",
  "license": "MIT",
  "homepage": "https://github.com/vinacogroup/flowctl",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "flowctl",
    "workflow",
    "mcp",
    "cursor",
    "workflow-orchestration",
    "workflow-orchestration-mcp",
    "workflow-orchestration-mcp-server",
    "workflow-orchestration-mcp-server-shell-proxy",
    "workflow-orchestration-mcp-server-workflow-state",
    "shell-proxy",
    "workflow-state"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin",
    "scripts/flowctl.sh",
    "scripts/workflow",
    "templates",
    "workflows/dispatch",
    "workflows/gates",
    "workflows/policies"
  ],
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run setup-hooks"
    }
  },
  "bin": {
    "flowctl": "./bin/flowctl"
  },
  "scripts": {
    "setup-hooks": "node scripts/setup-git-hooks.mjs",
    "flowctl": "flowctl",
    "test": "bash scripts/test-workflow-tdd-regression.sh",
    "test:tdd": "bash scripts/test-workflow-tdd-regression.sh",
    "test:e2e": "bash scripts/test-workflow-e2e.sh",
    "test:ci": "npm run test:tdd",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "release:push": "git push --follow-tags",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  }
}
